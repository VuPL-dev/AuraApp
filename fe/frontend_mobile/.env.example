# ===============================================
# AURA Accessories - Flutter Mobile App
# Environment Variables Template
# ===============================================
# Copy file này thành `.env` và điền giá trị thật:
#   cp .env.example .env
#
# LƯU Ý: KHÔNG commit file `.env` thật lên git (đã được .gitignore chặn).

# ===== Gemini AI =====
# API key lấy từ Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Base URL của Gemini API (thường để mặc định)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Model AI. Các model hợp lệ:
#   - gemini-flash-lite-latest  (nhẹ, nhanh, miễn phí)
#   - gemini-flash-latest       (cân bằng)
#   - gemini-2.0-flash          (ổn định, free tier rộng)
#   - gemini-2.5-flash          (mới nhất, có thinking)
GEMINI_MODEL=gemini-flash-lite-latest
